  "workflows": {
    "feature_development": [
      "coordinator → scope assessment (Diff-Scope Heuristic) → tier",
      "If new-ui-surface: architect (delta design + ADR if structural) → designer (delta tokens + component inventory + drill-down-spec.md if SaaS+dashboard)",
      "coordinator → backend + frontend (parallel with worktrees + TDD); PreToolUse security hook auto-blocks dangerous code patterns",
      "If existing project + SaaS scope touched: trigger Section 34 readiness audit pattern before completion",
      "reviewer + qa-engineer + auditor + designer (3-4 way parallel based on diff scope) → iteration loop with rollback on regression",
      "devops → git-ops (PR with 180s auto-reviewer wait) → coordinator (completion)"
    ],
    "bug_fix": [
      "coordinator → qa-engineer (Investigation Mode: reproduce + cross-boundary trace + LOOKUP audit + hypothesis via sequential-thinking) → root cause + recommended fix (NOT applied)",
      "coordinator → severity triage (P0 hotfix path vs P1-P3 standard)",
      "coordinator → backend|frontend (fix implementation with regression test FIRST); PreToolUse security hook prevents accidental dangerous patterns",
      "qa-engineer (re-verify) + reviewer (regression diff) + auditor (if stability/perf area) → iteration loop with rollback if verify fails",
      "git-ops (PR + hotfix branch if P0) → coordinator (completion)"
    ],
    "infrastructure_change": [
      "coordinator → architect (design validation + impact analysis)",
      "architect → devops (implementation + IaC)",
      "devops → reviewer (config review + security check)",
      "reviewer → coordinator (deployment approval)"
    ],
    "refactoring": [
      "coordinator → architect (target architecture + migration strategy)",
      "auditor → BEFORE metrics (cyclomatic, duplication, dead code, type-escape, file/function size)",
      "If has_visual_change: designer (component update spec)",
      "coordinator → backend|frontend (incremental refactor in small batches with TDD); PreToolUse security hook prevents introducing dangerous patterns",
      "qa-engineer → smoke verify per batch (golden path still works); if fails → rollback batch",
      "auditor → AFTER metrics + delta vs baseline; refactor without measurable improvement = wasted effort flagged",
      "reviewer (intent preserved + no behavioral drift + design token discipline if UI) → git-ops (staged PRs)"
    ],
    "security_audit": [
      "coordinator → reviewer (full security scan + OWASP check)",
      "reviewer → architect (architecture-level findings)",
      "architect → backend + frontend + devops (parallel fixes)",
      "all → reviewer (re-validation)",
      "reviewer → coordinator (audit report)"
    ],
    "data_migration": [
      "coordinator → architect (migration strategy + rollback plan)",
      "architect → backend (migration scripts + data validation)",
      "backend → devops (staging environment + backup)",
      "devops → reviewer (dry-run validation)",
      "reviewer → coordinator (go/no-go decision)"
    ],
    "performance_optimization": [
      "coordinator → reviewer (profiling + bottleneck identification)",
      "reviewer → architect (architecture-level optimizations)",
      "architect → backend + frontend (parallel optimization)",
      "backend + frontend → reviewer (benchmark validation)",
      "reviewer → devops (monitoring + alerting updates)",
      "devops → coordinator (completion with metrics)"
    ],
    "new_project_setup": [
      "coordinator → architect (full architecture design + tech stack)",
      "architect → devops (project scaffolding + CI/CD + environments)",
      "devops → backend + frontend (parallel initial implementation)",
      "backend + frontend → reviewer (initial code review + standards check)",
      "reviewer → git-ops (repo setup + branch protection + PR templates)",
      "git-ops → coordinator (project ready)"
    ],
    "saas_readiness_audit": [
      "coordinator → reviewer (parallel: docs/saas-readiness-security.md — auth gaps + compliance + CVE + CSP/HSTS)",
      "coordinator → auditor (parallel: docs/saas-readiness-operational.md — backup automation + CI/CD + observability + migration safety)",
      "coordinator → architect (parallel: docs/saas-readiness-business.md — trial enforcement + Stripe Tax + plan downgrade + onboarding lifecycle + status page + annual billing)",
      "architect synthesizes → docs/saas-readiness-master-report.md (Combined P0/P1/P2 + day-by-day pre-launch sprint + Phase 7/v2 backlog)",
      "If P0 count > 0: BLOCK new feature work AND BLOCK Phase 6 SHIP until P0 cleared (override via .dev-squad/ship-exceptions.md)",
      "Pattern: saas-patterns Part 3 Section 34 — applies to existing-project feature work + Phase 6 SHIP gate"
    ],
    "zero_to_ship": [
      "Phase 0 ULTRAPLAN: coordinator (deep thinking, master-plan.md) + Step 2.5 SaaS-mode auto-detect from PRD keywords + AskUserQuestion confirm → locked in master-plan.md",
      "Phase 1 DISCOVER: coordinator → architect (brainstorm + research + PRD generation) → USER CHECKPOINT (PRD approval)",
      "Phase 2 DESIGN: coordinator → architect (architecture + C4 + ADR-001..005 if SaaS: tenancy/billing/plan/admin/compliance) → reviewer (threat model parallel)",
      "Phase 3 SCAFFOLD: coordinator → devops (monorepo + Docker + CI/CD + monitoring) + git-ops (repo init + branch protection); If SaaS: scaffold backend modules tenants/plans/billing/webhooks/api-keys/audit-log/notifications/admin",
      "Phase 3.5 DESIGN (UI/UX, BLOCKING anti-AI-slop gate): coordinator → designer (4 artifacts: design-tokens + visual-spec + component-inventory + responsive-spec) + drill-down-spec.md if SaaS+dashboard",
      "Phase 4 IMPLEMENT: coordinator → writer (content) FIRST → backend + frontend (parallel with worktrees + TDD); SaaS: backend Part 1 + frontend Part 2 + PreToolUse security hook auto-blocks 9 dangerous code patterns",
      "Phase 5 REVIEW (3-way parallel + formal iteration loop): reviewer (static security/perf/spec/arch) + qa-engineer (Phase 5.5 functional + Visual Gate) + auditor (Phase 5.6 stability + 5.7 quality metrics) → reviewer synthesizes Phase5 Metrics Report; iteration loop max 5 with rollback on regression",
      "Phase 6 SHIP: If SaaS: BLOCKING readiness gate (reviewer+auditor+architect parallel readiness reports → master report → BLOCK if P0>0). devops (staging deploy + backup + CI/CD + status page if SaaS) + git-ops (PR + 180s auto-reviewer wait) → reviewer (final sign-off). Pre-seed CLAUDE.md + .claude/architecture.md + .claude/conventions.md + .claude/gotchas.md",
      "Phase 7 LEARN (PDCA Act): reviewer (retrospective.md) → coordinator (playbook.md + next-iteration.md + CLAUDE.md update + episodic memory write)"
    ]
  },
  "guardrails": {
    "max_parallel_agents": 21,
    "require_review_before_merge": true,
    "coordinator_must_approve": true,
    "max_task_duration_minutes": 120,
    "require_tests_before_pr": true,
    "require_security_check": true,
    "require_adr_for_architecture_changes": true,
    "max_pr_size_lines": 500,
    "require_rollback_plan_for_migrations": true
  },
  "autonomous_behavior": {
    "use_skills_without_asking": true,
    "use_mcp_without_asking": true,
    "lookup_docs_automatically": true,
    "search_patterns_automatically": true,
    "run_tests_before_completion": true,
    "search_conversation_history": true,
    "use_browser_for_testing": true,
    "track_issues_automatically": true,
    "update_project_knowledge": true,
    "create_adr_for_decisions": true,
    "profile_before_optimizing": true,
    "audit_dependencies_on_review": true
  },
  "enterprise_patterns": {
    "architecture_decision_records": true,
    "conventional_commits": true,
    "semantic_versioning": true,
    "trunk_based_development": true,
    "feature_flags": true,
