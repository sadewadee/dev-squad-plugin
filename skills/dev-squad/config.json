  "workflows": {
    "feature_development": [
      "coordinator → architect (design review + ADR)",
      "architect → backend + frontend (parallel implementation with worktrees)",
      "backend + frontend → reviewer (code review + security scan)",
      "reviewer → devops (deployment config + staging)",
      "devops → git-ops (branch/PR management)",
      "git-ops → coordinator (completion report)"
    ],
    "bug_fix": [
      "coordinator → reviewer (root cause via issuetracker + systematic-debugging)",
      "reviewer → backend|frontend (fix implementation with TDD)",
      "backend|frontend → reviewer (validation + regression check)",
      "reviewer → git-ops (PR creation + hotfix if critical)",
      "git-ops → coordinator (completion)"
    ],
    "infrastructure_change": [
      "coordinator → architect (design validation + impact analysis)",
      "architect → devops (implementation + IaC)",
      "devops → reviewer (config review + security check)",
      "reviewer → coordinator (deployment approval)"
    ],
    "refactoring": [
      "coordinator → architect (target architecture + migration strategy)",
      "architect → reviewer (review current code quality metrics)",
      "reviewer → backend|frontend (incremental refactor with TDD)",
      "backend|frontend → reviewer (verify no regression + improved metrics)",
      "reviewer → git-ops (staged PRs)",
      "git-ops → coordinator (completion)"
    ],
    "security_audit": [
      "coordinator → reviewer (full security scan + OWASP check)",
      "reviewer → architect (architecture-level findings)",
      "architect → backend + frontend + devops (parallel fixes)",
      "all → reviewer (re-validation)",
      "reviewer → coordinator (audit report)"
    ],
    "data_migration": [
      "coordinator → architect (migration strategy + rollback plan)",
      "architect → backend (migration scripts + data validation)",
      "backend → devops (staging environment + backup)",
      "devops → reviewer (dry-run validation)",
      "reviewer → coordinator (go/no-go decision)"
    ],
    "performance_optimization": [
      "coordinator → reviewer (profiling + bottleneck identification)",
      "reviewer → architect (architecture-level optimizations)",
      "architect → backend + frontend (parallel optimization)",
      "backend + frontend → reviewer (benchmark validation)",
      "reviewer → devops (monitoring + alerting updates)",
      "devops → coordinator (completion with metrics)"
    ],
    "new_project_setup": [
      "coordinator → architect (full architecture design + tech stack)",
      "architect → devops (project scaffolding + CI/CD + environments)",
      "devops → backend + frontend (parallel initial implementation)",
      "backend + frontend → reviewer (initial code review + standards check)",
      "reviewer → git-ops (repo setup + branch protection + PR templates)",
      "git-ops → coordinator (project ready)"
    ],
    "zero_to_ship": [
      "Phase 1 DISCOVER: coordinator → architect (brainstorm + research + PRD generation) → USER CHECKPOINT",
      "Phase 2 DESIGN: coordinator → architect (architecture + C4 diagrams + ADR) → reviewer (threat model)",
      "Phase 3 SCAFFOLD: coordinator → devops (project structure + Docker + CI/CD) + git-ops (repo init + branch protection)",
      "Phase 4 IMPLEMENT: coordinator → backend + frontend (parallel implementation with worktrees + TDD)",
      "Phase 5 REVIEW: coordinator → reviewer (full code review + OWASP audit + dependency scan + performance check)",
      "Phase 6 SHIP: coordinator → devops (staging deploy) + git-ops (PR creation) → reviewer (final sign-off) → coordinator (completion report)"
    ]
  },
  "guardrails": {
    "max_parallel_agents": 12,
    "require_review_before_merge": true,
    "coordinator_must_approve": true,
    "max_task_duration_minutes": 120,
    "require_tests_before_pr": true,
    "require_security_check": true,
    "require_adr_for_architecture_changes": true,
    "max_pr_size_lines": 500,
    "require_rollback_plan_for_migrations": true
  },
  "autonomous_behavior": {
    "use_skills_without_asking": true,
    "use_mcp_without_asking": true,
    "lookup_docs_automatically": true,
    "search_patterns_automatically": true,
    "run_tests_before_completion": true,
    "search_conversation_history": true,
    "use_browser_for_testing": true,
    "track_issues_automatically": true,
    "update_project_knowledge": true,
    "create_adr_for_decisions": true,
    "profile_before_optimizing": true,
    "audit_dependencies_on_review": true
  },
  "enterprise_patterns": {
    "architecture_decision_records": true,
    "conventional_commits": true,
    "semantic_versioning": true,
    "trunk_based_development": true,
    "feature_flags": true,
    "blue_green_deployment": true,
    "circuit_breaker_pattern": true,
    "health_check_endpoints": true,
    "structured_logging": true,
    "distributed_tracing": true
  }
}
