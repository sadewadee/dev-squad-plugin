{
  "workflow_id": "feature-development",
  "schema_version": "1.0",
  "version": "4.15.3",
  "name": "Feature Development",
  "description": "Add a new feature to existing project. Diff-scope-aware: dispatch tier varies by scope. Coordinator applies Diff-Scope Heuristic to choose lanes. PreToolUse security hook auto-blocks 9 dangerous code patterns (eval, dangerouslySetInnerHTML, child_process.exec, pickle, etc.). Phase 4 review uses formal iteration loop with rollback on regression. If existing project is SaaS-class and feature touches SaaS subsystems, Section 34 readiness audit may be triggered before completion.",
  "trigger_command": "/dev-squad feature",
  "phases": [
    {
      "id": "scope_assessment",
      "number": "1",
      "name": "Scope Assessment",
      "lead_agent": "dev-squad:coordinator",
      "trigger": "workflow_start",
      "inputs": [
        { "artifact": "user_description", "from": "user", "required": true }
      ],
      "outputs": [
        { "artifact": ".dev-squad/scope-tier.json", "to": "coordinator", "blocking": true, "description": "Diff-scope tier: trivial | tiny | new-endpoint | new-interactive-ui | new-ui-surface | db-change | auth-change | refactor | bug-fix | hotfix. Plus SaaS-touch flag: true if feature touches multi-tenancy/billing/webhooks/audit/api-keys/admin scope (triggers Section 34 readiness check before completion)." }
      ],
      "estimated_complexity": "low",
      "rate_limit_tier": "sonnet",
      "external_skills": {
        "preferred": [
          { "skill": "superpowers:brainstorming", "rationale": "Decompose feature requirements", "graceful_degrade": true, "invoked_by": "coordinator" }
        ],
        "fallback": "Manual scope assessment via Diff-Scope Heuristic table"
      },
      "references": {
        "prompt_source": "agents/dev-squad/coordinator.md#diff-scope-dispatch-heuristic",
        "agent_prompt": "agents/dev-squad/coordinator.md"
      }
    },
    {
      "id": "design",
      "number": "2",
      "name": "Architecture Review (conditional)",
      "lead_agent": "dev-squad:architect",
      "trigger": "scope.tier in ['new-endpoint', 'new-ui-surface', 'db-change', 'auth-change']",
      "inputs": [
        { "artifact": ".dev-squad/scope-tier.json", "from": "coordinator", "required": true }
      ],
      "outputs": [
        { "artifact": ".dev-squad/feature-design.md", "to": "implementers", "blocking": false, "description": "Architecture impact + ADR if structural" }
      ],
      "skip_conditions": [
        { "condition": "scope.tier in ['trivial', 'tiny', 'bug-fix']", "action": "skip", "fallback": "Skip architect; proceed directly to implementer" }
      ],
      "estimated_complexity": "medium",
      "rate_limit_tier": "opus",
      "external_skills": {
        "preferred": [
          { "skill": "gsd-plan-phase", "rationale": "Spec-driven planning when feature is non-trivial", "graceful_degrade": true, "invoked_by": "architect" }
        ],
        "fallback": "Manual via architect agent prompt + context7"
      },
      "references": {
        "prompt_source": "agents/dev-squad/coordinator.md#feature-development",
        "agent_prompt": "agents/dev-squad/architect.md"
      }
    },
    {
      "id": "ui_design",
      "number": "2.5",
      "name": "UI Design (conditional)",
      "lead_agent": "dev-squad:designer",
      "trigger": "scope.tier == 'new-ui-surface' || (scope.has_ui && scope.tier in ['new-endpoint', 'auth-change'])",
      "inputs": [
        { "artifact": ".dev-squad/feature-design.md", "from": "architect", "required": false }
      ],
      "outputs": [
        { "artifact": ".dev-squad/design/feature-design-tokens.md", "to": "frontend", "blocking": false, "description": "Delta tokens if feature introduces new color/type/spacing" },
        { "artifact": ".dev-squad/design/feature-component-inventory.md", "to": "frontend", "blocking": true, "description": "New components needed for this feature" },
        { "artifact": ".dev-squad/design/feature-responsive-spec.md", "to": "frontend", "blocking": true, "description": "Responsive wireframes for new pages/surfaces" }
      ],
      "skip_conditions": [
        { "condition": "scope.has_ui == false", "action": "skip", "fallback": "Backend-only; designer not dispatched" },
        { "flag": "--mvp-mode", "action": "slim", "fallback": "Slim deliverable: component inventory only" }
      ],
      "estimated_complexity": "medium",
      "rate_limit_tier": "sonnet",
      "external_skills": {
        "preferred": [
          { "skill": "ui-ux-pro-max", "rationale": "Design intelligence for new UI surfaces", "graceful_degrade": true, "invoked_by": "designer" },
          { "skill": "frontend-design:frontend-design", "rationale": "Distinctive frontend design", "graceful_degrade": true, "invoked_by": "designer" }
        ],
        "fallback": "Manual via WebSearch references"
      },
      "references": {
        "prompt_source": "agents/dev-squad/designer.md",
        "agent_prompt": "agents/dev-squad/designer.md"
      }
    },
    {
      "id": "implement",
      "number": "3",
      "name": "Implement",
      "lead_agent": "dev-squad:coordinator",
      "parallel_agents": ["dev-squad:backend", "dev-squad:frontend"],
      "trigger": "design.complete || scope.tier in ['trivial', 'tiny', 'bug-fix']",
      "inputs": [
        { "artifact": ".dev-squad/feature-design.md", "from": "architect", "required": false },
        { "artifact": ".dev-squad/design/feature-component-inventory.md", "from": "designer", "required": false }
      ],
      "outputs": [
        { "artifact": "feature commits", "to": "review", "blocking": true, "description": "Code + tests on feature branch. PreToolUse hook (guard-unsafe-code.py) auto-blocks dangerous code patterns during Edit/Write/MultiEdit." }
      ],
      "estimated_complexity": "medium",
      "rate_limit_tier": "sonnet",
      "external_skills": {
        "preferred": [
          { "skill": "superpowers:test-driven-development", "rationale": "TDD enforced", "graceful_degrade": true, "invoked_by": "backend,frontend" },
          { "skill": "dev-squad:saas-patterns", "rationale": "Load when scope-tier touches SaaS subsystems (multi-tenancy/billing/webhooks/audit/api-keys/admin) — backend Part 1 + frontend Part 2 contracts", "graceful_degrade": false, "invoked_by": "backend,frontend" }
        ],
        "fallback": "Direct dispatch via Agent tool with worktree isolation"
      },
      "references": {
        "prompt_source": "agents/dev-squad/coordinator.md#feature-development"
      }
    },
    {
      "id": "review",
      "number": "4",
      "name": "Review (Diff-Scope Heuristic)",
      "lead_agent": "dev-squad:reviewer",
      "parallel_agents": ["dev-squad:qa-engineer", "dev-squad:auditor", "dev-squad:designer"],
      "trigger": "implement.complete",
      "inputs": [
        { "artifact": "feature diff", "from": "implementers", "required": true },
        { "artifact": ".dev-squad/scope-tier.json", "from": "coordinator", "required": true }
      ],
      "outputs": [
        { "artifact": ".dev-squad/dispatch-log.md", "to": "future_audit", "blocking": false, "description": "Heuristic dispatch log entry" },
        { "artifact": ".dev-squad/iteration-log.md", "to": "coordinator", "blocking": false, "description": "Phase 4 iteration loop log: per-iter fix attempts, verifications, rollbacks. Max 5 iterations. Anti-thrashing: skip to escalation if same failure as prior iter. Rollback rule: if fix breaks existing passing test → git restore immediately. Smaller scale than zero-to-ship Phase 5 but same discipline." },
        { "artifact": "review verdict", "to": "git-ops", "blocking": true, "description": "P0/P1 must be resolved before merge. If iter > 5 unresolved → escalate to user with blast radius assessment." }
      ],
      "skip_conditions": [
        { "condition": "scope.tier == 'trivial'", "action": "slim", "fallback": "Reviewer light pass only; skip qa-engineer + auditor + designer" }
      ],
      "estimated_complexity": "medium",
      "rate_limit_tier": "sonnet",
      "external_skills": {
        "preferred": [
          { "skill": "code-review:code-review", "rationale": "Structured PR review", "graceful_degrade": true, "invoked_by": "reviewer" },
          { "skill": "playwright-skill:playwright-skill", "rationale": "Runtime verification of new UI/endpoint", "graceful_degrade": true, "invoked_by": "qa-engineer" }
        ],
        "fallback": "Manual via 3-way parallel Agent dispatch"
      },
      "references": {
        "prompt_source": "agents/dev-squad/coordinator.md#diff-scope-dispatch-heuristic"
      }
    },
    {
      "id": "deploy",
      "number": "5",
      "name": "Deploy",
      "lead_agent": "dev-squad:devops",
      "parallel_agents": ["dev-squad:git-ops"],
      "trigger": "review.complete",
      "outputs": [
        { "artifact": "GitHub PR + staging deploy", "to": "user", "blocking": true, "description": "PR creation includes mandatory 180s wait for auto-reviewers (Gemini/Copilot/CodeRabbit) before checking comment threads; address all unresolved threads before merge." }
      ],
      "estimated_complexity": "low",
      "rate_limit_tier": "sonnet",
      "external_skills": {
        "preferred": [
          { "skill": "superpowers:finishing-a-development-branch", "rationale": "Structured PR finalization", "graceful_degrade": true, "invoked_by": "git-ops" },
          { "skill": "gsd-pr-branch", "rationale": "PR pattern", "graceful_degrade": true, "invoked_by": "git-ops" }
        ],
        "fallback": "Manual via gh CLI"
      },
      "references": {
        "prompt_source": "agents/dev-squad/coordinator.md#feature-development"
      }
    }
  ]
}
